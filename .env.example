HTTP_ADDR=
HTTP_SHUTDOWN_TIMEOUT=

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_TIMEOUT=

LOGGER_LEVEL=

# JWT: HS256 access tokens; opaque refresh stored hashed (SHA-256 hex). SECRET must be >= 32 characters.
JWT_SECRET=
JWT_ACCESS_TTL=
JWT_REFRESH_TTL=

# Optional. If RESEND_API_KEY is empty, OTP is only written to application logs (not sent by email).
RESEND_API_KEY=
# Required when RESEND_API_KEY is set: verified sender in Resend (e.g. "App <onboarding@resend.dev>").
RESEND_FROM=